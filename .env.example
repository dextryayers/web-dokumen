# ─────────────────────────────────────────────
# HackIT Documentation - Environment Variables
# ─────────────────────────────────────────────

# Site URL for SEO/sitemap generation
SITE_URL=https://hackit.dev

# ─── Gemini API Key for HackIT AI Chat Assistant ───
# This is REQUIRED for the AI assistant sidebar to work.
# Get your FREE API key at: https://aistudio.google.com/apikey
#
# After getting the key, copy this file to .env and replace the value:
#   cp .env.example .env
#
# Then edit .env and paste your key:
#   PUBLIC_GEMINI_API_KEY=AIzaSy...
#
# NOTE: The key is inlined at build time into the client JS bundle.
#       For production, use a restricted API key or a proxy backend.
#       Currently using gemini-2.5-flash model (switch in AIAssistant.astro if needed).
PUBLIC_GEMINI_API_KEY=[api_key_here]
