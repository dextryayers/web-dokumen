---
const { t } = Astro.props;

const badgeIcons = [
  "M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5",
  "M3 15v4l9 5 9-5v-4M3 10v4l9 5 9-5v-4M3 5v4l9 5 9-5V5l-9-5-9 5z",
  "M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20zm0 18a8 8 0 1 1 0-16 8 8 0 0 1 0 16zm-3-9h6v2H9z",
  "M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z",
  "M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8zm11-3l2 2-4 4-2-2 4-4zm0 0l2-2M11 17l-4 4-2-2 4-4 2 2z",
  "M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z",
];
---

<section class="relative py-20 px-4">
  <div class="absolute inset-0 bg-[var(--bg-secondary)] border-y border-[var(--border)] pointer-events-none"></div>
  <div class="max-w-5xl mx-auto text-center relative z-10">
    <div class="mb-10">
      <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-emerald-500/20 bg-emerald-500/5 text-xs font-semibold text-emerald-400 mb-4 pulse-ring">{t.features.additionalBadge}</span>
      <h2 class="section-title mb-4">{t.features.additionalTitle}</h2>
      <p class="text-[var(--text-secondary)] text-sm max-w-lg mx-auto">{t.features.additionalDesc}</p>
    </div>

    <div class="flex flex-wrap justify-center gap-3" id="badge-container" data-reveal-stagger="0.07">
      {t.badges.map((badge, i) => (
        <span
          class="group inline-flex items-center gap-2.5 px-5 py-2.5 rounded-full border border-[var(--border)] bg-[var(--card-bg)] text-sm font-medium text-[var(--text-secondary)] hover:text-[var(--accent)] hover:border-[var(--accent)]/40 hover:shadow-[0_0_24px_var(--accent-glow)] hover:-translate-y-0.5 transition-all duration-300 cursor-default reveal-badge"

        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--accent)] opacity-0 group-hover:opacity-100 transition-all duration-300 shrink-0 group-hover:rotate-0 -rotate-90">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          {badge}
        </span>
      ))}
    </div>
  </div>
</section>


