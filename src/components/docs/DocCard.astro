---
const { type, title } = Astro.props as { type: "info" | "warning" | "tip" | "danger"; title?: string };
const config = {
  info: { border: "border-blue-500/30", bg: "bg-blue-500/5", icon: "text-blue-400", svg: '<path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/>' },
  warning: { border: "border-amber-500/30", bg: "bg-amber-500/5", icon: "text-amber-400", svg: '<path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>' },
  tip: { border: "border-emerald-500/30", bg: "bg-emerald-500/5", icon: "text-emerald-400", svg: '<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>' },
  danger: { border: "border-red-500/30", bg: "bg-red-500/5", icon: "text-red-400", svg: '<circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/>' },
};
const c = config[type];
---

<div class={"rounded-xl border " + c.border + " " + c.bg + " p-5 my-6 transition-all duration-200 hover:shadow-lg hover:shadow-[var(--shadow-color)]"}>
  <div class="flex items-start gap-3">
    <div class={"w-5 h-5 mt-0.5 shrink-0 transition-transform duration-200 group-hover:scale-110 " + c.icon} set:html={c.svg} />
    <div class="min-w-0">
      {title && <p class="font-semibold text-base mb-1.5">{title}</p>}
      <div class="text-sm text-[var(--text-secondary)] leading-relaxed">
        <slot />
      </div>
    </div>
  </div>
</div>
