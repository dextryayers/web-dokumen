---
const { lang, items } = Astro.props as { lang: string; items: { label: string; href?: string }[] };
---

<nav class="flex items-center gap-2 text-xs text-[var(--text-muted)] mb-6">
  <a href={"/" + lang + "/docs/"} class="hover:text-[var(--accent)] transition-colors">Docs</a>
  {items.map((item, i) => (
    <>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
      {item.href ? (
        <a href={item.href} class="hover:text-[var(--accent)] transition-colors">{item.label}</a>
      ) : (
        <span class="text-[var(--text-secondary)]">{item.label}</span>
      )}
    </>
  ))}
</nav>
