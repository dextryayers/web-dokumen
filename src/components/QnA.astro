---
const { t } = Astro.props;
const qna = t.qna;
---

<section class="relative py-24 px-4 overflow-hidden" id="qna-section" data-reveal>
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[var(--bg-secondary)]/20 to-transparent pointer-events-none"></div>
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[var(--border)] to-transparent"></div>

  <div class="max-w-4xl mx-auto relative z-10 reveal-qna">
    <div class="text-center mb-14">
      <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-[var(--accent)]/20 bg-[var(--accent)]/5 text-xs font-semibold text-[var(--accent)] mb-4">Q&A</span>
      <h2 class="section-title mb-4">{qna.title}</h2>
    </div>

    <div class="space-y-4">
      {qna.items.map((item, i) => (
        <div class="qna-item group glow-card overflow-hidden">
          <button class="qna-toggle w-full flex items-center justify-between gap-4 p-5 sm:p-6 text-left cursor-pointer" data-index={i}>
            <span class="text-base sm:text-lg font-semibold text-[var(--text)] pr-4">{item.q}</span>
            <svg class="qna-chevron shrink-0 w-5 h-5 text-[var(--text-muted)] transition-transform duration-300" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          <div class="qna-answer overflow-hidden max-h-0 opacity-0" data-index={i}>
            <div class="px-5 sm:px-6 pb-5 sm:pb-6 pt-0">
              <div class="w-12 h-0.5 rounded-full bg-[var(--accent)]/40 mb-4"></div>
              <p class="text-sm text-[var(--text-secondary)] leading-relaxed">{item.a}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .qna-answer { transition: max-height 0.35s ease-in-out, opacity 0.3s ease-in-out; }
  .qna-answer.open { opacity: 1 !important; }
  .qna-chevron { transition: transform 0.3s ease-in-out; }
  .qna-chevron.open { transform: rotate(180deg); }
</style>

<script>
try {
(function () {
  var rm = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var toggles = document.querySelectorAll('.qna-toggle');
  toggles.forEach(function (btn) {
    btn.addEventListener('click', function () {
      var index = this.getAttribute('data-index');
      var answer = document.querySelector('.qna-answer[data-index="' + index + '"]');
      var chevron = this.querySelector('.qna-chevron');
      if (!answer) return;
      var isOpen = answer.classList.contains('open');
      if (rm) { answer.style.transition = 'none'; if (chevron) chevron.style.transition = 'none'; }
      if (isOpen) {
        answer.style.maxHeight = '0px';
        answer.classList.remove('open');
        if (chevron) chevron.classList.remove('open');
      } else {
        var sh = answer.scrollHeight;
        answer.style.maxHeight = (sh && sh >= 10 ? sh : 600) + 'px';
        answer.classList.add('open');
        if (chevron) chevron.classList.add('open');
      }
    });
  });
})();
} catch(e) { console.error('QnA:', e); }
</script>
