---
const { t, lang } = Astro.props;
const isDocPage = Astro.url.pathname.includes('/docs/');

const sections = [
  {
    title: "Quick Links",
    links: [
      { label: t.footer.docs, href: `/${lang}/docs/getting-started` },
      { label: t.footer.github, href: "https://github.com/dextryayers/HackIT", external: true },
      { label: t.footer.license, href: "https://github.com/dextryayers/HackIT/blob/main/LICENSE", external: true },
      { label: "Quick Reference", href: "https://github.com/dextryayers/HackIT/blob/main/QUICK_REFERENCE.md", external: true },
    ],
  },
  {
    title: "Modules",
    links: [
      { label: "Port Scanner", href: "https://github.com/dextryayers/HackIT/tree/main/hackit/port_scanner/go", external: true },
      { label: "OSINT Engine", href: "https://github.com/dextryayers/HackIT/tree/main/modules", external: true },
      { label: "Web Fuzzer", href: "https://github.com/dextryayers/HackIT/tree/main/hackit/web_fuzzer", external: true },
      { label: "AI Agent", href: "https://github.com/dextryayers/HackIT/tree/main/hackit/agent", external: true },
    ],
  },
  {
    title: "Resources",
    links: [
      { label: "API Reference", href: "https://github.com/dextryayers/HackIT/blob/main/MODULE_API_REFERENCE.md", external: true },
      { label: "Setup Guide", href: `/${lang}/docs/guide` },
      { label: "CLI Commands", href: `/${lang}/docs/reference` },
      { label: "Wordlists", href: "https://github.com/dextryayers/HackIT/tree/main/wordlists", external: true },
    ],
  },
];

const socials = [
  {
    label: "GitHub",
    href: "https://github.com/dextryayers/HackIT",
    icon: '<path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>',
  },
];
---

<footer class="relative border-t border-[var(--border)] bg-[var(--bg)] overflow-hidden">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-[var(--accent)]/5 rounded-full blur-[100px]"></div>
    <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-[100px]"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10" class:list={{ 'lg:ml-96': isDocPage }}>
    <div class="py-16 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-10 lg:gap-8" data-reveal>
      <div class="sm:col-span-2 lg:col-span-2">
        <div class="flex items-center gap-3 mb-4">
          <img src="/img/logo.png" alt="HackIT Logo" width="40" height="40" class="object-contain" />
          <div>
            <span class="text-base font-bold gradient-text">HackIT</span>
            <p class="text-[11px] text-[var(--text-muted)]">v2.1.0 Apex &middot; Hexa-Engine Security Suite</p>
          </div>
        </div>
        <p class="text-sm text-[var(--text-secondary)] leading-relaxed max-w-sm mb-6">
          {t.footer.description}
        </p>
        <div class="flex flex-wrap items-center gap-3">
          <a href="https://github.com/dextryayers/HackIT" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-2.5 px-5 py-2.5 rounded-xl text-sm font-medium border border-[var(--border)] bg-[var(--card-bg)] text-[var(--text-secondary)] hover:text-[var(--accent)] hover:border-[var(--accent)]/30 hover:shadow-[0_0_20px_var(--accent-glow)] transition-all duration-300">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="group-hover:scale-110 transition-transform duration-300"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            {t.footer.starText}
          </a>
          <div class="flex items-center gap-2">
            <span class="w-6 h-6 rounded-lg bg-[var(--bg-tertiary)] border border-[var(--border)] flex items-center justify-center text-[10px] font-bold text-[var(--text-muted)]">A</span>
            <span class="w-6 h-6 rounded-lg bg-[var(--bg-tertiary)] border border-[var(--border)] flex items-center justify-center text-[10px] font-bold text-[var(--text-muted)]">2.0</span>
          </div>
        </div>
      </div>

      {sections.map((sec) => (
        <div>
          <h4 class="text-xs font-semibold uppercase tracking-widest text-[var(--text-muted)] mb-4 relative inline-block">
            {sec.title}
            <span class="absolute -bottom-1 left-0 w-8 h-0.5 rounded-full bg-[var(--accent)]"></span>
          </h4>
          <ul class="space-y-3 pt-3">
            {sec.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  target={link.external ? "_blank" : undefined}
                  rel={link.external ? "noopener noreferrer" : undefined}
                  class="group inline-flex items-center gap-1.5 text-sm text-[var(--text-secondary)] hover:text-[var(--accent)] transition-all duration-200"
                >
                  <span class="w-0 group-hover:w-1.5 h-0.5 rounded-full bg-[var(--accent)] transition-all duration-200"></span>
                  {link.label}
                  {link.external && (
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="opacity-0 -ml-1 group-hover:opacity-100 group-hover:ml-0 transition-all duration-200"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                  )}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="py-6 border-t border-[var(--border)] flex flex-col sm:flex-row items-center justify-between gap-3" data-reveal data-reveal-delay="0.1">
      <p class="text-[11px] text-[var(--text-muted)]">{t.footer.copyright}</p>
      <div class="flex items-center gap-4">
        <p class="text-[11px] text-[var(--text-muted)]">Built with Astro</p>
        <span class="w-1 h-1 rounded-full bg-[var(--text-muted)]"></span>
        <p class="text-[11px] text-[var(--text-muted)]">Apache 2.0 &amp; MIT</p>
        <span class="w-1 h-1 rounded-full bg-[var(--text-muted)]"></span>
        <p class="text-[11px] text-[var(--text-muted)]">Open Source</p>
      </div>
    </div>
  </div>

  <button id="back-to-top" class="back-to-top fixed bottom-6 right-6 z-40 w-10 h-10 rounded-xl bg-[var(--accent)] text-white shadow-lg shadow-[var(--accent-glow)] hover:shadow-xl hover:shadow-[var(--accent-glow)] hover:-translate-y-1 transition-all duration-300 flex items-center justify-center">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg>
  </button>
</footer>

<script>
try {
(function () {
  var btn = document.getElementById('back-to-top');
  if (!btn) return;
  window.addEventListener('scroll', function () {
    btn.classList.toggle('visible', window.scrollY > 400);
  });
  btn.addEventListener('click', function () {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
})();
} catch(e) { console.error('Footer:', e); }
</script>
