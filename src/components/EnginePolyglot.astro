---
const { t } = Astro.props;
const engines = t.engines;
import { svgLogo } from "./svgLogos";
---

<section class="relative py-28 px-4 overflow-hidden" id="engines-section">
  <div class="absolute inset-0 bg-gradient-to-b from-[var(--bg-secondary)]/20 via-transparent to-[var(--bg-secondary)]/20 pointer-events-none"></div>
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[var(--accent)]/30 to-transparent"></div>

  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 rounded-full bg-[var(--accent)]/5 blur-3xl"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 rounded-full bg-[var(--accent)]/3 blur-3xl"></div>
  </div>

  <div class="max-w-5xl mx-auto relative z-10">
    <div class="text-center mb-16 sm:mb-20" data-reveal>
      <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-[var(--accent)]/20 bg-[var(--accent)]/5 text-xs font-semibold text-[var(--accent)] mb-4 pulse-ring tracking-wider uppercase">Architecture</span>
      <h2 class="section-title mb-4">{engines.title}</h2>
      <p class="text-[var(--text-secondary)] text-sm sm:text-base max-w-3xl mx-auto leading-relaxed">{engines.desc}</p>
    </div>

    <div class="relative" id="engine-roadmap">
      <div class="hidden md:block absolute left-1/2 -translate-x-px top-0 bottom-0 w-0.5 bg-gradient-to-b from-[var(--accent)]/50 via-[var(--accent)]/20 to-transparent"></div>
      <div class="block md:hidden absolute left-[23px] top-0 bottom-0 w-0.5 bg-gradient-to-b from-[var(--accent)]/50 via-[var(--accent)]/20 to-transparent"></div>

      {engines.items.map((engine, i) => {
        const isLeft = i % 2 === 0;
        const marginClass = i === 0 ? "mt-0" : "mt-10";
        const lineClass = i === engines.items.length - 1 ? "" : "pb-8 md:pb-12";
        return (
          <div class={`relative flex items-start gap-6 ${marginClass} ${lineClass} roadmap-node`} data-reveal data-reveal-delay={i * 0.12}>
            <div class="hidden md:flex absolute top-6 left-1/2 -translate-x-1/2 z-20">
              <div class="w-12 h-12 rounded-full flex items-center justify-center overflow-hidden transition-all duration-500 roadmap-dot p-2" style={{background: "linear-gradient(135deg, " + engine.color + "25, " + engine.color + "10)", border: "2px solid " + engine.color + "40", boxShadow: "0 0 0 4px " + engine.color + "15, 0 4px 16px " + engine.color + "20"}}>
                <span class="w-full h-full lang-icon" set:html={svgLogo[engine.lang]}></span>
              </div>
            </div>

            <div class="shrink-0 relative z-10 md:z-0 md:absolute md:top-6 md:left-1/2 md:-translate-x-1/2">
              <div class="md:hidden w-12 h-12 rounded-xl flex items-center justify-center overflow-hidden shadow-lg transition-all duration-500 roadmap-icon md:w-14 md:h-14 p-2.5" style={{background: "linear-gradient(135deg, " + engine.color + "25, " + engine.color + "10)", border: "1px solid " + engine.color + "30", boxShadow: "0 4px 20px " + engine.color + "20"}}>
                <span class="w-full h-full lang-icon drop-shadow-sm" set:html={svgLogo[engine.lang]}></span>
              </div>
            </div>

            <div class={`flex-1 min-w-0 md:w-[calc(50%-3rem)] ${isLeft ? "md:pr-0 md:mr-auto" : "md:pl-0 md:ml-auto"}`}>
              <div class={`md:flex md:items-start md:gap-5 ${!isLeft ? "md:flex-row-reverse" : ""}`}>
                <div class="hidden md:block shrink-0 w-14 h-14 rounded-xl flex items-center justify-center overflow-hidden shadow-lg transition-all duration-500 roadmap-icon p-2.5" style={{background: "linear-gradient(135deg, " + engine.color + "25, " + engine.color + "10)", border: "1px solid " + engine.color + "30", boxShadow: "0 4px 20px " + engine.color + "20"}}>
                  <span class="w-full h-full lang-icon drop-shadow-sm" set:html={svgLogo[engine.lang]}></span>
                </div>

                <div class="flex-1 min-w-0 roadmap-card-wrapper">
                  <div class="group relative overflow-hidden roadmap-card hover-lift rounded-xl sm:rounded-2xl p-5 sm:p-7" style={{background: "linear-gradient(135deg, var(--bg-secondary), var(--bg))", border: "1px solid " + engine.color + "15", boxShadow: "0 4px 24px -6px rgba(0,0,0,0.2), inset 0 0 0 0 transparent"}}>
                    <div class="absolute -inset-px rounded-xl sm:rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none" style={{background: "linear-gradient(135deg, " + engine.color + "15, transparent 60%)"}}></div>

                    <div class="absolute top-0 left-0 w-1 h-full rounded-r transition-all duration-300 group-hover:w-1.5" style={{background: "linear-gradient(to bottom, " + engine.color + ", " + engine.color + "80)"}}></div>

                    <div class="relative z-10">
                      <div class="flex items-center gap-3 mb-4">
                        <div class="w-10 h-10 rounded-lg flex items-center justify-center overflow-hidden p-2 sm:hidden flex-shrink-0" style={{background: "linear-gradient(135deg, " + engine.color + "25, " + engine.color + "10)", border: "1px solid " + engine.color + "30"}}>
                          <span class="w-full h-full lang-icon" set:html={svgLogo[engine.lang]}></span>
                        </div>
                        <div class="min-w-0 flex-1">
                          <div class="flex items-center gap-3 flex-wrap">
                            <h3 class="text-base sm:text-lg font-bold text-[var(--text)] tracking-tight">{engine.lang}</h3>
                            <span class="text-[10px] font-semibold uppercase tracking-wider px-2.5 py-1 rounded-md" style={{background: engine.color + "18", color: engine.color, border: "1px solid " + engine.color + "25"}}>{engine.badge}</span>
                          </div>
                          <span class="text-xs sm:text-sm text-[var(--text-muted)] font-medium tracking-wide">{engine.role}</span>
                        </div>
                      </div>

                      <p class="text-sm sm:text-base text-[var(--text-secondary)] leading-relaxed sm:leading-7">{engine.desc}</p>
                    </div>

                    <div class="absolute bottom-0 right-0 w-24 h-24 opacity-[0.03] group-hover:opacity-[0.06] transition-opacity duration-500 pointer-events-none">
                      <span class="w-full h-full lang-icon" set:html={svgLogo[engine.lang]}></span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  .lang-icon svg { width: 100%; height: 100%; display: block; }
  .lang-icon { display: flex; align-items: center; justify-content: center; }

  .hover-lift {
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.35s ease, border-color 0.35s ease;
    will-change: transform;
  }
  .hover-lift:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 48px -12px rgba(0,0,0,0.3);
  }

  .roadmap-dot {
    transition: transform 0.35s ease, box-shadow 0.35s ease, border-color 0.35s ease;
  }
  .roadmap-node:hover .roadmap-dot {
    transform: scale(1.15);
    box-shadow: 0 0 24px var(--accent-glow);
    border-color: var(--accent);
  }

  .roadmap-card-wrapper {
    perspective: 1000px;
  }
</style>

