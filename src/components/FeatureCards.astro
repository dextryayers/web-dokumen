---
const { t } = Astro.props;

const cards = [
  {
    icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>',
    gradient: "from-blue-500/20 to-cyan-500/20",
    accent: "text-blue-400",
  },
  {
    icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>',
    gradient: "from-purple-500/20 to-pink-500/20",
    accent: "text-purple-400",
  },
  {
    icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>',
    gradient: "from-emerald-500/20 to-teal-500/20",
    accent: "text-emerald-400",
  },
  {
    icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>',
    gradient: "from-orange-500/20 to-rose-500/20",
    accent: "text-orange-400",
  },
  {
    icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>',
    gradient: "from-pink-500/20 to-rose-500/20",
    accent: "text-pink-400",
  },
  {
    icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 17H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2h-1"/><polygon points="12 15 17 21 7 21 12 15"/></svg>',
    gradient: "from-amber-500/20 to-yellow-500/20",
    accent: "text-amber-400",
  },
  {
    icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>',
    gradient: "from-indigo-500/20 to-violet-500/20",
    accent: "text-indigo-400",
  },
];
---

<section class="relative py-24 px-4">
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[var(--bg-secondary)]/50 to-transparent pointer-events-none"></div>
  <div class="max-w-6xl mx-auto relative z-10">
    <div class="text-center mb-14">
      <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-[var(--accent)]/20 bg-[var(--accent)]/5 text-xs font-semibold text-[var(--accent)] mb-4">{t.features.badge}</span>
      <h2 class="section-title mb-4">{t.features.title}</h2>
      <p class="text-[var(--text-secondary)] max-w-lg mx-auto text-sm">{t.features.subtitle}</p>
    </div>

    <div class="marquee-wrapper relative overflow-hidden" style="mask-image:linear-gradient(to right,transparent 0%,black 4%,black 96%,transparent 100%);-webkit-mask-image:linear-gradient(to right,transparent 0%,black 4%,black 96%,transparent 100%)">
      <div id="cards-track" class="flex gap-5 w-max py-2" style="will-change:transform">
        {[...t.features.cards, ...t.features.cards, ...t.features.cards, ...t.features.cards].map((card, i) => {
          const c = cards[i % cards.length];
          return (
            <div class="group relative reveal-card w-[280px] shrink-0 gradient-border" data-reveal data-reveal-delay={(i % cards.length) * 0.1}>
              <div class={`absolute -inset-0.5 bg-gradient-to-br ${c.gradient} rounded-2xl opacity-0 group-hover:opacity-100 blur-md transition-opacity duration-500`}></div>
              <div class="glow-card p-6 relative bg-[var(--card-bg)] h-full flex flex-col">
                <div class={`w-11 h-11 rounded-xl flex items-center justify-center mb-4 ${c.accent} bg-[var(--bg-tertiary)] border border-[var(--border)] group-hover:border-current/30 group-hover:bg-current/5 group-hover:scale-110 transition-all duration-300`} set:html={c.icon}></div>
                <h3 class="font-bold text-[15px] mb-2 group-hover:text-[var(--accent)] transition-colors duration-300">{card.title}</h3>
                <p class="text-sm text-[var(--text-secondary)] leading-relaxed flex-1">{card.desc}</p>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </div>
</section>

<script>
try {
(function () {
  var track = document.getElementById('cards-track');
  if (!track) return;
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

  var step = track.scrollWidth / 4;
  var speed = 40;
  var pos = 0;
  var paused = false;
  var lastTime = null;
  track.style.transform = 'translateX(0px)';

  function frame(time) {
    if (paused) {
      lastTime = null;
      requestAnimationFrame(frame);
      return;
    }
    if (lastTime === null) lastTime = time;
    var dt = Math.min((time - lastTime) * 0.001, 0.1);
    lastTime = time;
    pos -= speed * dt;
    if (pos <= -step) pos += step;
    track.style.transform = 'translateX(' + pos.toFixed(1) + 'px)';
    requestAnimationFrame(frame);
  }

  track.addEventListener('mouseenter', function () { paused = true; });
  track.addEventListener('mouseleave', function () { paused = false; });
  document.addEventListener('visibilitychange', function () {
    paused = document.hidden;
  });

  requestAnimationFrame(frame);
})();
} catch(e) { console.error('FeatureCards:', e); }
</script>
