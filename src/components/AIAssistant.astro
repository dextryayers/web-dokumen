  function renderMarkdown(text) {
    var html = escapeHtml(text);
    html = html.replace(/```(\w*)\n?([\s\S]*?)```/g, function(m, lang, code) {
      var label = lang ? '<div class="code-lang">' + lang + '</div>' : '';
      return '<div class="code-block">' + label + '<pre><code>' + code + '</code></pre></div>';
    });
    html = html.replace(/`([^`]+)`/g, '<code>$1</code>');
    html = html.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
    html = html.replace(/\*([^*]+)\*/g, '<em>$1</em>');
    html = html.replace(/^- (.+)$/gm, '<li>$1</li>');
    html = html.replace(/((?:<li>.*?<\/li>(?:\n|$)?)+)/g, '<ul>$1</ul>');
    var paragraphs = html.split(/\n{2,}/);
    if (paragraphs.length > 1 || !/^<(?:pre|ul|ol|h\d)/.test(html)) {
      html = paragraphs.map(function(p) {
        p = p.trim();
        if (!p) return '';
        if (/^<(?:pre|ul|ol|h\d)/.test(p)) return p;
        return '<p>' + p + '</p>';
      }).join('');
    }
    html = html.replace(/<pre><code><\/code><\/pre>/g, '');
    return html;
  }

