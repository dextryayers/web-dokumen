    bubble.appendChild(content);
    var chipsDiv = document.createElement('div');
    chipsDiv.className = 'flex flex-wrap gap-1.5 mt-2.5 pt-2.5 border-t border-[var(--border)]';
    var icons = ['<svg class="w-3 h-3 inline-block mr-1 -mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>','<svg class="w-3 h-3 inline-block mr-1 -mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 16 16 12 12 8"/></svg>','<svg class="w-3 h-3 inline-block mr-1 -mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>','<svg class="w-3 h-3 inline-block mr-1 -mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>'];
    t.chips.forEach(function(c, i) {
      var btn = document.createElement('button');
      btn.className = 'ai-chip text-[11px] px-2.5 py-1 rounded-full border border-[var(--border)] text-[var(--text-secondary)] transition-all duration-200 cursor-pointer';
      btn.innerHTML = icons[i] + c[1];
      btn.dataset.prompt = c[0];
      chipsDiv.appendChild(btn);
    });
    bubble.appendChild(chipsDiv);
    var feedback = document.createElement('div');
    feedback.className = 'ai-feedback';
    feedback.innerHTML = '<button class="fb-btn fb-like" title="Like"><svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3H14zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg></button><button class="fb-btn fb-dislike" title="Dislike"><svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 15v4a3 3 0 0 0 3 3l4-9V2H5.72a2 2 0 0 0-2 1.7l-1.38 9a2 2 0 0 0 2 2.3H10zM17 2h2.67A2.31 2.31 0 0 1 22 4v7a2.31 2.31 0 0 1-2.33 2H17"/></svg></button>';
    bubble.appendChild(feedback);
    row.appendChild(bubble);
    messages.appendChild(row);
  }

  function setLoading(loading) {
    sendBtn.disabled = loading;
    sendBtn.innerHTML = loading
      ? '<svg class="w-4 h-4 animate-spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" fill="none" stroke-dasharray="31.4 31.4" stroke-linecap="round"/></svg>'
      : '<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>';
  }

  function formatError(errText) {
    if (errText.indexOf('API_KEY') !== -1 || errText.indexOf('API key') !== -1) {
      return 'Invalid API key. Please set a valid <code>PUBLIC_GEMINI_API_KEY</code> in your <code>.env</code> file. Get your key at <a href="https://aistudio.google.com/apikey" target="_blank" rel="noopener">Google AI Studio</a>.';
    }
    if (errText.indexOf('SAFETY') !== -1 || errText.indexOf('safety') !== -1) {
      return 'I couldn\'t generate a response due to safety filters. Please try rephrasing your question.';
    }
    if (errText.indexOf('is not found') !== -1 || errText.indexOf('NOT_FOUND') !== -1) {
      return '⚠️ **Model not available**\n\nThe Gemini model for this API key is not found. Try a different model or get a new API key at [Google AI Studio](https://aistudio.google.com/apikey).';
    }
    if (errText.indexOf('limit: 0') !== -1 || errText.indexOf('RESOURCE_EXHAUSTED') !== -1) {
      return '⚠️ **Daily free quota exhausted**\n\nThis API key\'s daily limit is used up for this model. The free tier resets at **midnight Pacific time**.\n\nTo fix now:\n1. Get a **new key from a different Google Cloud project** at [Google AI Studio](https://aistudio.google.com/apikey)\n2. Manage existing keys at [Google Cloud Console](https://console.cloud.google.com/apis/credentials)\n3. **Enable billing** on your project for 1,500 free requests/day then pay-as-you-go\n\nOr just **wait** — it\'ll reset automatically.';
    }
    if (errText.indexOf('429') !== -1 || errText.indexOf('RATE_LIMIT') !== -1) {
      return '⚠️ **Rate limit hit** — too many requests per minute. Please wait **30-60 seconds**, then try again.';
    }
    if (errText.indexOf('quota') !== -1) {
      return '⚠️ **API quota exceeded**\n\nGemini free tier daily quota is used up. You can:\n1. Wait until the quota resets (usually daily)\n2. Get a **new key via different Google Cloud project** at [Google AI Studio](https://aistudio.google.com/apikey)\n3. Enable billing on your Google Cloud project for higher limits';
    }
    return '⚠️ **Something went wrong**\n\nThe Gemini API returned an error. Check your API key and internet connection, then try again.';
  }

  async function sendMessage() {
    var text = input.value.trim();
    if (!text || isLoading) return;
    var now = Date.now();
    if (now - lastRequestTime < MIN_REQUEST_INTERVAL) {
      var wait = Math.ceil((MIN_REQUEST_INTERVAL - (now - lastRequestTime)) / 1000);
      addMessage('model', '⏳ Please wait **' + wait + 's** before sending another message (rate limit protection).');
      isLoading = false;
      setLoading(false);
      input.value = text;
      updateSendBtn();
      return;
    }
    lastRequestTime = now;
    isLoading = true;
    input.value = '';
    input.style.height = 'auto';
    updateSendBtn();
    setLoading(true);
    addMessage('user', text);
    conversation.push({ role: 'user', parts: [{ text: text }] });
    showTyping();
    try {
      var apiKey = getApiKey();
      if (!apiKey) {
        removeTyping();
        addMessage('model', '⚠️ **API Key not configured**\n\nTo use HackIT AI, set your Gemini API key in the `.env` file:\n\n```\nPUBLIC_GEMINI_API_KEY=your_api_key_here\n```\n\nGet a free key at: https://aistudio.google.com/apikey');
        setLoading(false);
        return;
      }
      if (apiKey.indexOf('AIza') !== 0 || apiKey.length < 30) {
        removeTyping();
        addMessage('model', '⚠️ **Invalid API key format**\n\nThe key in `.env` doesn\'t look valid. Google Gemini keys start with `AIza...` and are ~39 characters.\n\nGet a new key at: https://aistudio.google.com/apikey\n\nAfter updating `.env`, **restart the dev server** or **rebuild** (`npm run build`) for the change to take effect.');
        setLoading(false);
        return;
      }
      var chatHistory = conversation.map(function(msg) { return { role: msg.role, parts: msg.parts }; });
      var res = await fetch('https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=' + apiKey, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          system_instruction: { parts: [{ text: SYSTEM_PROMPT }] },
          contents: chatHistory,
          generationConfig: {
            temperature: 0.4,
            maxOutputTokens: 2048,
            topP: 0.92,
            topK: 40
          },
          safetySettings: [
            { category: 'HARM_CATEGORY_HARASSMENT', threshold: 'BLOCK_NONE' },
            { category: 'HARM_CATEGORY_HATE_SPEECH', threshold: 'BLOCK_NONE' },
            { category: 'HARM_CATEGORY_SEXUALLY_EXPLICIT', threshold: 'BLOCK_NONE' },
            { category: 'HARM_CATEGORY_DANGEROUS_CONTENT', threshold: 'BLOCK_NONE' }
          ]
        })
      });
      removeTyping();
      if (!res.ok) {
        var err = await res.text();
        addMessage('model', formatError(err));
        setLoading(false);
        return;
      }
      var data = await res.json();
      var reply = data && data.candidates && data.candidates[0] && data.candidates[0].content && data.candidates[0].content.parts && data.candidates[0].content.parts[0] ? data.candidates[0].content.parts[0].text : 'No response generated. Please try rephrasing your question.';
      addMessage('model', reply);
      conversation.push({ role: 'model', parts: [{ text: reply }] });
    } catch (err) {
      removeTyping();
      var msg = err.message || '';
      if (msg.indexOf('fetch') !== -1 || msg.indexOf('network') !== -1) {
        addMessage('model', '⚠️ **Network Error**\n\nUnable to reach the Gemini API. Please check your internet connection and try again.');
      } else {
        addMessage('model', '⚠️ **Unexpected Error**\n\nAn unexpected error occurred: `' + escapeHtml(msg || 'Unknown') + '`\n\nPlease try again.');
      }
    } finally {
      isLoading = false;
      setLoading(false);
    }
  }

  if (toggle) {
    toggle.addEventListener('click', togglePanel);
  }

  if (headerClose) {
    headerClose.addEventListener('click', function(e) {
      createRipple(e, headerClose);
      if (isOpen) togglePanel();
    });
  }

  if (backdrop) {
    backdrop.addEventListener('click', function() {
      if (isOpen) togglePanel();
    });
  }
  sendBtn.addEventListener('click', function(e) { createRipple(e, sendBtn); sendMessage(); });
  input.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
  });
  input.addEventListener('input', autoResize);

  // Delegated clicks: chips + copy
  messages.addEventListener('click', function(e) {
    var chip = e.target.closest('.ai-chip, .ai-followup');
    if (chip) {
      var prompt = chip.dataset.prompt;
      if (prompt) sendViaChip(prompt);
      return;
    }
    var fb = e.target.closest('.fb-btn');
    if (fb) {
      if (fb.classList.contains('permanent')) return;
      var container = fb.closest('.ai-feedback');
      if (!container) return;
      var all = container.querySelectorAll('.fb-btn');
      all.forEach(function(b) { b.classList.add('permanent'); });
      fb.classList.add('active');
      return;
    }
    var btn = e.target.closest('.ai-copy-btn');
    if (!btn) return;
    var text = btn.getAttribute('data-copy-text');
    if (!text) return;
    navigator.clipboard.writeText(text).then(function() {
      btn.innerHTML = '<svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>';
      btn.classList.add('text-green-500');
      setTimeout(function() {
        btn.innerHTML = '<svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
        btn.classList.remove('text-green-500');
      }, 2000);
    });
  });

  if (backdrop) {
    backdrop.addEventListener('click', function() {
      if (isOpen) togglePanel();
    });
  }

  clearBtn.addEventListener('click', function(e) {
    createRipple(e, clearBtn);
    var welcome = messages.querySelector('[data-index="welcome"]');
    while (messages.lastChild) { messages.removeChild(messages.lastChild); }
    if (welcome) messages.appendChild(welcome);
    else showWelcome();
    conversation = [];
    input.focus();
    scrollToBottom();
  });

  input.placeholder = t.placeholder;
  var onlineLabel = document.getElementById('ai-online-label');
  if (onlineLabel) onlineLabel.textContent = t.online;
  showWelcome();
  updateSendBtn();
  togglePanel();
})();
</script>
