---
// AI Assistant - Right Side Panel
---

<div id="ai-root" class="fixed inset-0 z-50 pointer-events-none">
  <!-- Backdrop -->
  <div id="ai-backdrop" class="fixed inset-0 bg-black/60 backdrop-blur-sm transition-all duration-300 ease-out pointer-events-auto hidden" style="opacity:0"></div>

  <!-- Toggle Tab - vertical rectangle on right edge -->
  <button id="ai-toggle" class="fixed right-0 top-1/2 -translate-y-1/2 z-[60] pointer-events-auto flex flex-col items-center justify-center gap-1.5 w-9 h-24 rounded-l-lg rounded-r-none bg-[var(--accent)] text-white shadow-lg hover:shadow-xl hover:brightness-110 active:brightness-95 transition-all duration-200 cursor-pointer border-none outline-none select-none" aria-label="Toggle AI Assistant" aria-expanded="false">
    <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
    <span class="text-[9px] font-bold uppercase tracking-widest" style="writing-mode:vertical-rl;text-orientation:mixed">AI</span>
  </button>
  <!-- Chat Panel -->
  <div id="ai-panel" class="fixed right-0 top-0 h-full w-full sm:w-[440px] z-50 pointer-events-auto flex flex-col bg-[var(--card-bg)] border-l border-[var(--border)] shadow-2xl" style="box-shadow:-8px 0 48px rgba(0,0,0,0.18)">
    <!-- Header -->
    <div class="flex items-center gap-2 px-4 py-3 border-b border-[var(--border)] bg-[var(--bg-secondary)]/80 backdrop-blur-xl shrink-0 relative">
      <div class="absolute inset-x-0 top-0 h-px header-shimmer"></div>
      <div class="absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-purple-500/15 to-transparent"></div>
      <button id="ai-header-close" class="p-1.5 rounded-lg hover:bg-[var(--bg-tertiary)] text-[var(--text-muted)] hover:text-[var(--text)] transition-all duration-200 -ml-1 ripple-btn" title="Close">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
      <div class="w-8 h-8 rounded-xl bg-gradient-to-br from-[var(--accent)]/20 to-purple-600/20 flex items-center justify-center ring-1 ring-[var(--accent)]/20 shrink-0">
        <svg class="w-4 h-4 text-[var(--accent)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
      </div>
      <div class="flex-1 min-w-0">
        <h3 class="font-semibold text-sm text-[var(--text)] tracking-tight">HackIT AI</h3>
        <p class="text-[11px] text-[var(--text-muted)] flex items-center gap-1.5">
          HackIT AI 2.1
          <span class="inline-block w-1.5 h-1.5 rounded-full bg-emerald-500 shadow-sm shadow-emerald-500/50"></span>
          <span class="text-[10px] text-[var(--text-muted)]" id="ai-online-label">Online</span>
        </p>
      </div>
      <button id="ai-clear" class="p-1.5 rounded-lg hover:bg-[var(--bg-tertiary)] text-[var(--text-muted)] hover:text-[var(--text)] transition-all duration-200 relative group/clear -mr-1 ripple-btn" title="Clear conversation">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
        <span class="absolute -bottom-8 left-1/2 -translate-x-1/2 px-2 py-1 rounded-md bg-[var(--bg-tertiary)] border border-[var(--border)] text-[10px] text-[var(--text-muted)] whitespace-nowrap opacity-0 group-hover/clear:opacity-100 transition-opacity pointer-events-none">Clear chat</span>
      </button>
    </div>

    <!-- Messages -->
    <div id="ai-messages" class="flex-1 overflow-y-auto px-4 py-3 scroll-smooth flex flex-col"></div>

    <!-- Input Area -->
    <div class="shrink-0 border-t border-[var(--border)] px-4 py-3 relative">
      <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-[var(--accent)]/20 to-transparent"></div>
      <div class="flex items-center gap-2">
        <div class="flex-1 relative">
          <textarea id="ai-input" rows="1" placeholder="" class="w-full resize-none bg-[var(--bg-tertiary)] border border-[var(--border)] rounded-2xl px-4 py-[6px] pr-10 text-sm text-[var(--text)] placeholder:text-[var(--text-muted)] outline-none focus:border-[var(--accent)] focus:ring-1 focus:ring-[var(--accent)]/20 transition-all duration-200 max-h-32 leading-relaxed" style="scrollbar-width:thin"></textarea>
        </div>
        <button id="ai-send" class="w-9 h-9 rounded-xl bg-[var(--accent)] text-white active:scale-90 transition-all duration-200 flex items-center justify-center shrink-0 disabled:opacity-35 disabled:cursor-not-allowed shadow-lg shadow-[var(--accent)]/20 ripple-btn" disabled>
          <svg class="w-[15px] h-[15px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
        </button>
      </div>
      <p class="text-[9px] text-[var(--text-muted)] mt-2.5 px-1 opacity-80 tracking-wider font-bold">Powered by HackIT AI - Created By <a href="https://haniipp.space" target="_blank" rel="noopener" class="text-[var(--accent)] hover:underline">Hanif Abdurrohim</a></p>
    </div>
  </div>
</div>

<style is:global>
  /* ─── Header Shimmer ─── */
  .header-shimmer {
    background: linear-gradient(90deg, transparent, var(--accent), #8b5cf6, var(--accent), transparent);
    background-size: 200% 100%;
    animation: shimmerSlide 3s ease-in-out infinite;
  }
  @keyframes shimmerSlide {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  /* ─── Panel ─── */
  #ai-panel {
    transform: translateX(calc(100% + 2px));
    transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1),
                visibility 0s 0.45s;
    visibility: hidden;
    will-change: transform;
  }
  #ai-panel.open {
    transform: translateX(0);
    visibility: visible;
    transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1),
                visibility 0s 0s;
  }

  /* ─── Toggle Tab ─── */
  #ai-toggle {
    border-radius: 10px 0 0 10px;
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1),
                opacity 0.3s ease,
                visibility 0.3s ease,
                width 0.3s ease,
                background 0.3s ease,
                box-shadow 0.3s ease;
    z-index: 60;
    transform-origin: right center;
    backdrop-filter: blur(8px);
  }
  #ai-toggle:hover {
    width: 42px;
    background: var(--accent-hover);
  }
  #ai-toggle.hidden-toggle {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateX(16px) scale(0.85);
    animation: none;
  }
  #ai-toggle:not(.hidden-toggle) {
    animation: toggleGlow 3s ease-in-out infinite;
  }
  @keyframes toggleGlow {
    0%, 100% { box-shadow: 0 0 0 0 transparent; }
    50% { box-shadow: 0 0 20px 2px var(--accent-glow); }
  }

  /* ─── Backdrop ─── */
  #ai-backdrop {
    transition: opacity 0.4s ease-out, visibility 0s 0.4s;
    visibility: hidden;
    z-index: 40;
  }
  #ai-backdrop.show {
    opacity: 1;
    visibility: visible;
    transition: opacity 0.4s ease-out, visibility 0s 0s;
  }

  /* ─── Input ─── */
  #ai-input:focus {
    box-shadow: 0 0 0 2px var(--accent-glow), inset 0 0 0 1px var(--accent);
  }
  #ai-input::placeholder {
    color: var(--text-muted);
    opacity: 0.55;
    font-size: 13px;
  }

  /* ─── Send Button ─── */
  #ai-send:not(:disabled) {
    cursor: pointer;
  }
  #ai-send:not(:disabled):active {
    transform: scale(0.9);
  }
  #ai-send:not(:disabled):hover {
    box-shadow: 0 0 24px var(--accent-glow);
    filter: brightness(1.12);
  }
  #ai-send:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }

  /* ─── Messages Container ─── */
  #ai-messages {
    gap: 0;
    scrollbar-width: thin;
    scrollbar-color: transparent transparent;
    align-items: stretch;
    scroll-behavior: smooth;
  }
  #ai-messages:hover {
    scrollbar-color: var(--border) transparent;
  }
  #ai-messages::-webkit-scrollbar { width: 4px; }
  #ai-messages::-webkit-scrollbar-track { background: transparent; }
  #ai-messages::-webkit-scrollbar-thumb {
    background: transparent;
    border-radius: 8px;
    transition: background 0.3s ease;
  }
  #ai-messages:hover::-webkit-scrollbar-thumb {
    background: var(--border);
  }
  #ai-messages:hover::-webkit-scrollbar-thumb:hover { background: var(--text-muted); }

  /* ─── Message Rows ─── */
  .msg-row {
    display: flex;
    width: 100%;
    padding: 5px 0;
    animation: msgIn 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    align-items: flex-start;
    gap: 8px;
  }
  .msg-row.msg-user {
    justify-content: flex-end;
  }
  .msg-row + .msg-row {
    margin-top: 1px;
  }

  /* ─── Avatars ─── */
  .msg-avatar {
    width: 28px;
    min-width: 28px;
    height: 28px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    margin-top: 6px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.08);
    background: var(--bg-tertiary);
  }
  .msg-avatar img, .msg-avatar svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* ─── Message Column ─── */
  .msg-col {
    display: flex;
    flex-direction: column;
    min-width: 0;
    max-width: 82%;
  }
  .msg-row.msg-user .msg-col {
    max-width: 76%;
  }
  .msg-time {
    font-weight: 700;
    font-size: 9px;
    color: var(--text-muted);
    opacity: 0.5;
    letter-spacing: 0.02em;
  }
  .msg-time.user {
    text-align: right;
    padding: 0 4px 2px;
  }
  .msg-time.ai {
    margin-left: auto;
    font-size: 8px;
    opacity: 0.4;
  }

  /* ─── Message Grouping ─── */
  .msg-row.msg-user + .msg-row.msg-user {
    margin-top: 0;
    padding-top: 0;
  }
  .msg-row.msg-user + .msg-row.msg-user .msg-content.user {
    border-radius: 16px 4px 4px 16px;
  }
  .msg-row.msg-user + .msg-row.msg-user .msg-avatar {
    visibility: hidden;
  }
  .msg-row.msg-user + .msg-row.msg-user .msg-time {
    visibility: hidden;
  }
  .msg-row.msg-ai + .msg-row.msg-ai {
    margin-top: 0;
    padding-top: 0;
  }
  .msg-row.msg-ai + .msg-row.msg-ai .msg-content.ai {
    border-radius: 4px 16px 16px 4px;
  }
  .msg-row.msg-ai + .msg-row.msg-ai .msg-bubble.ai .msg-header {
    display: none;
  }
  .msg-row.msg-ai + .msg-row.msg-ai .msg-avatar {
    visibility: hidden;
  }
  .msg-row.msg-ai + .msg-row.msg-ai .msg-time {
    visibility: hidden;
  }
  @keyframes msgIn {
    from { opacity: 0; transform: translateY(10px) scale(0.97); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  .msg-bubble {
    max-width: 100%;
    min-width: 0;
  }

  .msg-bubble .msg-header {
    font-size: 10px;
    font-weight: 500;
    color: var(--text-muted);
    margin-bottom: 3px;
    display: flex;
    align-items: center;
    gap: 4px;
    letter-spacing: 0.02em;
    padding-left: 2px;
    width: 100%;
  }
  .msg-badge {
    font-size: 7.5px;
    padding: 1px 6px;
    border-radius: 999px;
    background: var(--accent);
    color: #fff;
    font-weight: 600;
    letter-spacing: 0.03em;
    opacity: 0.8;
  }

  .msg-content {
    border-radius: 16px;
    padding: 10px 14px;
    line-height: 1.6;
    font-size: 13px;
  }
  .msg-content.ai {
    background: var(--bg-secondary);
    box-shadow: 0 1px 4px rgba(0,0,0,0.04), 0 2px 8px rgba(0,0,0,0.02);
  }
  .msg-content.user {
    background: linear-gradient(135deg, var(--accent), color-mix(in srgb, var(--accent) 85%, #fff));
    color: #fff;
    border-radius: 16px 16px 4px 16px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  }
  .msg-content.user p { color: #fff; }

  .msg-content p { margin-bottom: 6px; font-size: 13px; line-height: 1.6; }
  .msg-content p:last-child { margin-bottom: 0; }
  .msg-content ul, .msg-content ol { padding-left: 18px; margin-bottom: 6px; font-size: 13px; }
  .msg-content li { margin-bottom: 3px; }
  .msg-content strong { color: var(--text); }
  .msg-content.user strong { color: #fff; }
  .msg-content a { color: var(--accent); text-decoration: underline; text-underline-offset: 2px; }
  .msg-content .code-block {
    margin: 8px 0;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--bg-tertiary);
  }
  .msg-content .code-lang {
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-muted);
    padding: 4px 12px;
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border);
    opacity: 0.6;
  }
  .msg-content pre {
    background: var(--bg-tertiary);
    padding: 12px 14px;
    margin: 0;
    overflow-x: auto;
    font-size: 12px;
    line-height: 1.55;
    border: none;
    border-radius: 0;
  }
  .msg-content code {
    font-size: 12px;
    padding: 1px 5px;
    border-radius: 4px;
    background: var(--bg-tertiary);
    color: var(--accent);
  }
  .msg-content pre code { background: none; padding: 0; color: inherit; }

  /* ─── Follow-up Chips ─── */
  .followup-chip {
    font-size: 10px;
    padding: 4px 10px;
    border-radius: 999px;
    border: 1px solid var(--border);
    color: var(--text-muted);
    background: var(--bg-secondary);
    cursor: pointer;
    transition: all 0.2s ease;
    user-select: none;
  }
  .followup-chip:hover {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
  }
  .followup-chip:active {
    transform: scale(0.95);
  }

  /* ─── AI Chips ─── */
  .ai-chip {
    user-select: none;
    -webkit-user-select: none;
    background: var(--bg-secondary);
    font-size: 11px;
    padding: 4px 10px;
    border-radius: 999px;
    border: 1px solid var(--border);
    color: var(--text-secondary);
    transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    cursor: pointer;
    opacity: 0;
    transform: translateY(6px);
    animation: chipIn 0.35s ease forwards;
  }
  .ai-chip:nth-child(1) { animation-delay: 0.5s; }
  .ai-chip:nth-child(2) { animation-delay: 0.6s; }
  .ai-chip:nth-child(3) { animation-delay: 0.7s; }
  .ai-chip:nth-child(4) { animation-delay: 0.8s; }
  @keyframes chipIn {
    to { opacity: 1; transform: translateY(0); }
  }
  .ai-chip:hover {
    background: var(--accent);
    color: white !important;
    border-color: var(--accent);
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  }
  .ai-chip:active {
    transform: scale(0.92);
  }

  .ai-followup {
    user-select: none;
    -webkit-user-select: none;
    font-size: 10px;
    padding: 4px 10px;
    border-radius: 8px;
    border: 1px solid var(--border);
    color: var(--text-muted);
    background: var(--bg-secondary);
    transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    cursor: pointer;
  }
  .ai-followup:hover {
    background: var(--accent) !important;
    color: white !important;
    border-color: var(--accent) !important;
    box-shadow: 0 2px 6px rgba(0,0,0,0.06);
  }
  .ai-followup:active {
    transform: scale(0.93);
  }

  /* ─── Feedback Buttons ─── */
  .ai-feedback {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-top: 8px;
    padding-top: 8px;
    border-top: 1px solid var(--border);
  }
  .fb-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border: none;
    border-radius: 8px;
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.15s ease;
    opacity: 0.4;
  }
  .fb-btn:hover {
    opacity: 1;
    background: var(--bg-tertiary);
  }
  .fb-like.active {
    opacity: 1;
    color: #22c55e;
    background: rgba(34, 197, 94, 0.1);
  }
  .fb-dislike.active {
    opacity: 1;
    color: #ef4444;
    background: rgba(239, 68, 68, 0.1);
  }
  .fb-btn.permanent {
    cursor: default;
  }
  .fb-btn.permanent:hover {
    background: inherit;
  }

  /* ─── Copy Button ─── */
  .msg-row.msg-ai {
    position: relative;
  }
  .ai-copy-btn {
    opacity: 0;
    transition: opacity 0.15s ease;
  }
  .msg-row.msg-ai:hover .ai-copy-btn {
    opacity: 1;
  }
  .ai-copy-btn:hover {
    opacity: 1;
  }

  /* ─── Typing Indicator ─── */
  .typing-dot {
    animation: typingBounce 1.4s ease-in-out infinite;
    background: var(--accent);
    border-radius: 999px;
  }
  .typing-dot:nth-child(2) { animation-delay: 0.15s; }
  .typing-dot:nth-child(3) { animation-delay: 0.3s; }
  @keyframes typingBounce {
    0%, 80%, 100% { transform: translateY(0); opacity: 0.35; }
    40% { transform: translateY(-6px); opacity: 1; }
  }

  /* ─── Ripple ─── */
  .ripple-btn {
    position: relative;
    overflow: hidden;
  }
  .ripple-btn .ripple {
    position: absolute;
    border-radius: 50%;
    background: rgba(255,255,255,0.3);
    transform: scale(0);
    animation: rippleAnim 0.5s ease-out;
    pointer-events: none;
  }
  @keyframes rippleAnim {
    to { transform: scale(4); opacity: 0; }
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  .animate-spin {
    animation: spin 1s linear infinite;
  }

  /* ─── Response Content (fallback) ─── */

  .text-green-500 { color: #22c55e; }

  /* ─── Responsive ─── */
  @media (max-width: 639px) {
    #ai-panel { width: 100%; max-width: 100%; }
    #ai-toggle { width: 32px; height: 100px; }
    #ai-toggle svg { width: 14px; height: 14px; }

    #ai-messages { padding: 10px 12px; }
    #ai-input { font-size: 0.8rem; padding: 10px 12px; }
    #ai-input::placeholder { font-size: 0.8rem; }
    .msg-content pre { font-size: 0.75rem; padding: 10px 12px; }
    .msg-content code { font-size: 0.75rem; }
    .msg-content { padding: 9px 12px; border-radius: 14px; }
    .msg-content.user { border-radius: 14px 14px 4px 14px; }
    .msg-col { max-width: 88% !important; }
    .msg-row.msg-user .msg-col { max-width: 85% !important; }
    #ai-send { width: 36px; height: 42px; }
    #ai-send svg { width: 14px; height: 14px; }
    .msg-avatar { width: 22px; min-width: 22px; height: 22px; margin-top: 8px; }
    .msg-row { gap: 5px; padding: 4px 0; }
  }

  @media (min-width: 640px) and (max-width: 1023px) {
    #ai-panel { width: 400px; max-width: 400px; }
    #ai-messages { padding: 12px 14px; }
  }
</style>

<script>
(function() {
  function getLang() {
    try {
      var stored = localStorage.getItem('lang');
      if (stored && ['en','id','it','ru','zh','ja'].indexOf(stored) !== -1) return stored;
      var m = window.location.pathname.match(/^\/(en|id|it|ru|zh|ja)\//);
      if (m) return m[1];
    } catch(e) {}
    return 'en';
  }
  var lang = getLang();
  var ai18n = {
    en: { welcome: "Hello! I'm **HackIT AI**, your intelligent assistant for the HackIT security framework. I can help with:\n\n- Installation & setup\n- Network scanning & recon\n- Vulnerability detection\n- CLI commands & usage\n- Architecture & modules\n\nAsk me anything!", chips: [['How do I install HackIT?','Install'],['How do I scan a network?','Network Scan'],['Apa itu HackIT? (ID)','Bahasa ID'],['List all CLI commands','CLI Commands']], placeholder: 'Ask HackIT AI anything...', online: 'Online', langInst: 'IMPORTANT: Always respond in **English**. If the user writes in another language, match their language.', fw: [['What are the prerequisites?','How to build from source?','Platform-specific tips?'],['What scan modes are available?','How to use stealth mode?','Port scanning best practices?'],['How to use autopilot?','Interactive console guide?','All available flags?'],['How do AI agents work?','What languages are used?','Module development guide?'],['How many agents?','Agent orchestration?','AI provider setup?'],['How to test for XSS?','How to detect SQL injection?','Reporting vulnerabilities?'],['Troubleshooting guide?','Common issues?','How to report bugs?'],['What wireless attacks are supported?','PMKID capture guide?','WPA3 cracking?'],['What OSINT sources are available?','Subdomain enumeration?','Email recon?'],['Tell me more','Show me an example','Any alternatives?']] },
