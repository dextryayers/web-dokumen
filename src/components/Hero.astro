---
const { t, lang } = Astro.props;
---

<section id="hero-section" class="relative min-h-screen flex items-center px-4 sm:px-6 lg:px-8 pt-28 pb-16 overflow-hidden">
  <div class="absolute inset-0 grid-bg pointer-events-none opacity-[0.03] dark:opacity-[0.06]"></div>

  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/4 -left-32 w-[600px] h-[600px] bg-[var(--glow-cyan)] rounded-full blur-[150px] opacity-50"></div>
    <div class="absolute bottom-1/4 -right-32 w-[500px] h-[500px] bg-[var(--glow-purple)] rounded-full blur-[150px] opacity-30"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-gradient-to-r from-[var(--glow-cyan)] to-[var(--glow-purple)] rounded-full blur-[200px] opacity-20"></div>
  </div>

  <div class="relative z-10 w-full max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
      <div class="order-2 lg:order-1">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-[var(--accent)]/30 bg-[var(--accent)]/5 text-xs font-semibold text-[var(--accent)] mb-6 reveal pulse-ring" data-reveal>
          <span class="w-1.5 h-1.5 rounded-full bg-[var(--accent)] animate-pulse"></span>
          {t.hero.tagline}
        </div>

        <h1 class="text-[2.5rem] sm:text-5xl md:text-6xl lg:text-7xl font-extrabold tracking-tight leading-[1.05] mb-6 reveal" data-reveal>
          <span class="gradient-text">HackIT</span>
          <br />
          <span class="text-[var(--text)]">Framework</span>
        </h1>

        <p class="text-base sm:text-lg text-[var(--text-secondary)] leading-relaxed max-w-xl mb-8 reveal" data-reveal>
          {t.hero.description}
        </p>

        <div class="flex items-center gap-3 mb-10 reveal" data-reveal>
          <span class="text-sm font-medium text-[var(--text-muted)] shrink-0 tracking-wide uppercase">{t.hero.toolsLabel}</span>
          <div class="h-8 flex items-center">
            <span id="typing-text" class="text-lg sm:text-xl font-bold text-[var(--accent)]"></span>
            <span class="typing-cursor"></span>
          </div>
        </div>

        <div class="flex flex-wrap items-center gap-3 reveal" data-reveal>
          <a href={`/${lang}/docs/getting-started`} class="group relative inline-flex items-center gap-2.5 px-7 py-3.5 rounded-xl text-sm font-semibold text-white bg-[var(--accent)] hover:bg-[var(--accent-hover)] transition-all duration-300 shadow-lg shadow-[var(--accent-glow)] hover:shadow-xl hover:shadow-[var(--accent-glow)] hover:-translate-y-0.5 overflow-hidden">
            <div class="absolute inset-0 bg-white/10 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            <span class="relative z-10 flex items-center gap-2">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
              {t.hero.quickStart}
            </span>
          </a>
          <a href="https://github.com/dextryayers/HackIT" target="_blank" rel="noopener noreferrer" class="group inline-flex items-center gap-2.5 px-7 py-3.5 rounded-xl text-sm font-semibold border border-[var(--border)] text-[var(--text)] hover:bg-[var(--bg-tertiary)] hover:border-[var(--accent)] transition-all duration-300 hover:-translate-y-0.5">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="group-hover:scale-110 transition-transform duration-300"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            {t.hero.repo}
          </a>
          <a href="#what-is-hackit" class="inline-flex items-center gap-1.5 px-5 py-3.5 rounded-xl text-sm font-semibold text-[var(--text-secondary)] hover:text-[var(--text)] transition-all duration-300 hover:-translate-y-0.5 group">
            {t.hero.whatIs}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-0.5 transition-transform duration-300"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </div>

      <div class="order-1 lg:order-2 flex justify-center lg:justify-end reveal" data-reveal>
        <div class="relative group">
          <div class="absolute -inset-4 bg-[var(--accent)]/10 rounded-full blur-2xl"></div>
          <div class="absolute -inset-2 bg-gradient-to-r from-[var(--accent)]/20 via-transparent to-purple-500/20 rounded-full blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
          <div class="relative z-10 p-2 rounded-2xl bg-[var(--card-bg)] border border-[var(--border)] shadow-xl group-hover:shadow-2xl group-hover:shadow-[var(--accent-glow)] transition-shadow duration-500">
            <div class="rounded-xl overflow-hidden">
              <img
                src="/img/logo.png"
                alt="HackIT Logo"
                class="w-56 h-56 sm:w-72 sm:h-72 lg:w-[26rem] lg:h-[26rem] object-contain group-hover:scale-[1.02] transition-transform duration-700"
                loading="eager"
                width="400"
                height="400"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1 text-[var(--text-muted)]">
    <span class="text-[10px] uppercase tracking-widest font-medium">Scroll</span>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="scroll-arrow"><path d="m6 9 6 6 6-6"/></svg>
  </div>
</section>

<script>

try {
(function () {
  var typingEl = document.getElementById('typing-text');
  if (!typingEl) return;
  var WORDS = ["Port Scanner", "SQL Injection", "XSS", "Wireless 802.11", "Subdomain Enum", "Directory Fuzzer", "OSINT Recon", "CVE Scanner", "AI Agent", "403 Bypass"];
  var wordIndex = 0, charIndex = 0, isDeleting = false;
  var rm = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (rm) { typingEl.textContent = WORDS[0]; return; }
  function tick() {
    var word = WORDS[wordIndex];
    if (!isDeleting) {
      charIndex++;
      typingEl.textContent = word.substring(0, charIndex);
      if (charIndex >= word.length) {
        setTimeout(function () { isDeleting = true; tick(); }, 2000);
      } else {
        setTimeout(tick, 75);
      }
    } else {
      charIndex--;
      typingEl.textContent = word.substring(0, charIndex);
      if (charIndex <= 0) {
        isDeleting = false;
        wordIndex = (wordIndex + 1) % WORDS.length;
        setTimeout(tick, 300);
      } else {
        setTimeout(tick, 35);
      }
    }
  }
  setTimeout(tick, 600);
})();
} catch(e) { console.error('Hero typing:', e); }

</script>
