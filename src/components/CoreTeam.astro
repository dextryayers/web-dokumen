---
const { t } = Astro.props;
const member = t.team.members[0];
const socials = [
  { label: "GitHub", href: member.github, brand: "#333" },
  { label: "Instagram", href: "https://instagram.com/hanziip.kds", brand: "#E4405F" },
  { label: "WhatsApp", href: "https://wa.me/6282332430578", brand: "#25D366" },
  { label: "LinkedIn", href: "https://linkedin.com/in/hanifabdurrohim", brand: "#0A66C2" },
  { label: "Web", href: "https://haniipp.space", brand: "#6366f1" },
  { label: "Labs", href: "https://haniplabs.com", brand: "#f59e0b" },
];
---

<section class="relative py-24 px-4 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[var(--bg-secondary)]/30 to-transparent pointer-events-none"></div>
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[var(--border)] to-transparent"></div>

  <div class="max-w-4xl mx-auto relative z-10" data-reveal>
    <div class="text-center mb-14">
      <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-[var(--accent)]/20 bg-[var(--accent)]/5 text-xs font-semibold text-[var(--accent)] mb-4">{t.team.title}</span>
      <h2 class="section-title mb-4">{t.team.title}</h2>
      <p class="text-[var(--text-secondary)] text-sm max-w-md mx-auto">{t.team.subtitle}</p>
    </div>

    <div class="glow-card p-6 sm:p-10 flex flex-col md:flex-row items-center md:items-start gap-8 md:gap-12">
      <div class="shrink-0">
        <div class="relative group/photo w-48 h-48 sm:w-56 sm:h-56">
          <div class="absolute -inset-2 bg-gradient-to-r from-[var(--accent)] via-purple-500 via-pink-500 to-cyan-500 rounded-2xl opacity-0 group-hover/photo:opacity-100 blur-md transition-all duration-700 animate-spin-slow group-hover/photo:blur-lg"></div>
          <div class="absolute -inset-1 bg-gradient-to-br from-[var(--accent)] via-purple-500 to-cyan-500 rounded-2xl opacity-0 group-hover/photo:opacity-60 transition-all duration-500"></div>
          <div class="relative w-full h-full rounded-2xl overflow-hidden border-2 border-[var(--border)] group-hover/photo:border-transparent transition-all duration-500 shadow-lg group-hover/photo:shadow-2xl group-hover/photo:shadow-[var(--accent-glow)] group-hover/photo:scale-105 group-hover/photo:rotate-1 group-hover/photo:[transform:perspective(800px)_rotateY(-4deg)] transition-all duration-500 ease-out">
            <img
              src="/img/author.jpeg"
              alt={member.name}
              class="w-full h-full object-cover group-hover/photo:scale-110 transition-transform duration-700"
              width="224"
              height="224"
              loading="lazy"
            />
          </div>
          <div class="absolute -bottom-2 -right-2 w-10 h-10 rounded-xl bg-[var(--card-bg)] border border-[var(--border)] flex items-center justify-center shadow-sm group-hover/photo:scale-110 group-hover/photo:rotate-12 transition-all duration-300">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </div>
        </div>
      </div>

      <div class="flex-1 text-center md:text-left">
        <h3 class="text-2xl sm:text-3xl font-extrabold gradient-text mb-1">{member.name}</h3>
        <p class="text-sm sm:text-base text-[var(--accent)] font-semibold mb-4">{member.role}</p>
        <p class="text-sm text-[var(--text-secondary)] leading-relaxed mb-6">{member.desc}</p>

        <div class="flex flex-wrap items-center justify-center md:justify-start gap-3">
          {socials.map((s) => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              class="group/social relative flex items-center gap-2 px-4 py-2.5 rounded-xl border border-[var(--border)] bg-[var(--card-bg)] text-sm font-medium text-[var(--text-secondary)] hover:text-white transition-all duration-300 overflow-hidden"
              style={`--social-brand: ${s.brand}`}
              aria-label={s.label}
            >
              <div class="absolute inset-0 rounded-xl opacity-0 group-hover/social:opacity-100 transition-opacity duration-300" style="background:var(--social-brand)"></div>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="relative z-10 group-hover/social:scale-110 transition-transform duration-300">
                {s.label === "GitHub" && <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>}
                {s.label === "Instagram" && <><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M12 8.5a3.5 3.5 0 100 7 3.5 3.5 0 000-7z"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor"/></>}
                {s.label === "WhatsApp" && <><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></>}
                {s.label === "LinkedIn" && <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>}
                {s.label === "Web" && <><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></>}
                {s.label === "Labs" && <path d="M9 3v2a6 6 0 0012 0V3M9 3H7m2 0h10m0 0a2 2 0 012 2v1a2 2 0 01-2 2m0-5a2 2 0 00-2 2v1a2 2 0 002 2m0 0v8a2 2 0 01-2 2H8a2 2 0 01-2-2v-8m0 0a2 2 0 00-2-2v0a2 2 0 012-2m0 0h2m0 0V3"/>}
              </svg>
              <span class="relative z-10">{s.label}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>


