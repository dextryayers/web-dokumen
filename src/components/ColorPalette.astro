---
const colors = [
  { name: "Cyan", light: "#06b6d4", dark: "#22d3ee" },
  { name: "Blue", light: "#3b82f6", dark: "#60a5fa" },
  { name: "Indigo", light: "#6366f1", dark: "#818cf8" },
  { name: "Purple", light: "#8b5cf6", dark: "#a78bfa" },
  { name: "Pink", light: "#ec4899", dark: "#f472b6" },
  { name: "Rose", light: "#f43f5e", dark: "#fb7185" },
  { name: "Orange", light: "#f97316", dark: "#fb923c" },
  { name: "Amber", light: "#f59e0b", dark: "#fbbf24" },
  { name: "Green", light: "#10b981", dark: "#34d399" },
  { name: "Emerald", light: "#059669", dark: "#10b981" },
];
---

<div id="color-palette" class="fixed bottom-6 left-6 z-50 flex flex-col items-start gap-2">
  <div id="palette-drawer" class="hidden flex-col gap-1.5 mb-2 palette-drawer">
    {colors.map(c => (
      <button
        class="palette-swatch w-9 h-9 rounded-full border-2 border-[var(--border)] shadow-lg hover:scale-110 hover:shadow-xl transition-all duration-200"
        style={{background: c.light}}
        data-light={c.light}
        data-dark={c.dark}
        aria-label={"Set accent color to " + c.name}
      ></button>
    ))}
    <button id="palette-reset" class="w-9 h-9 rounded-full border-2 border-[var(--border)] bg-[var(--bg-secondary)] shadow-lg flex items-center justify-center hover:scale-110 transition-all duration-200" aria-label="Reset to default">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
    </button>
  </div>

  <button id="palette-toggle" class="w-10 h-10 rounded-full bg-[var(--bg-secondary)] border border-[var(--border)] shadow-lg flex items-center justify-center hover:bg-[var(--bg-tertiary)] transition-all duration-200" aria-label="Toggle color palette">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="13.5" cy="6.5" r="0.5" fill="currentColor"/><circle cx="17.5" cy="10.5" r="0.5" fill="currentColor"/><circle cx="8.5" cy="7.5" r="0.5" fill="currentColor"/><circle cx="6.5" cy="12.5" r="0.5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12c0 2.5 1 5 2.5 6.5L12 22l2.5-2.5C16 18 20 14.5 20 12c0-1.5-.5-3-1.5-4"/><path d="m19 2 2 2-7 7-2-2 7-7z"/></svg>
  </button>
</div>

<script>
try {
(function () {
  var toggle = document.getElementById('palette-toggle');
  var drawer = document.getElementById('palette-drawer');
  var swatches = document.querySelectorAll('.palette-swatch');
  var resetBtn = document.getElementById('palette-reset');
  if (!toggle || !drawer) return;

  function parseColor(hex) {
    var r = parseInt(hex.slice(1,3), 16);
    var g = parseInt(hex.slice(3,5), 16);
    var b = parseInt(hex.slice(5,7), 16);
    return { r: r, g: g, b: b };
  }

  function applyAccent(lightHex, darkHex) {
    var light = parseColor(lightHex);
    var dark = parseColor(darkHex);

    var style = document.getElementById('accent-style');
    if (!style) {
      style = document.createElement('style');
      style.id = 'accent-style';
      document.head.appendChild(style);
    }

    style.textContent = ':root { --accent: ' + lightHex + '; --accent-hover: rgb(' + Math.max(light.r-30,0) + ',' + Math.max(light.g-30,0) + ',' + Math.max(light.b-30,0) + '); --accent-glow: rgba(' + light.r + ',' + light.g + ',' + light.b + ',0.18); } .dark { --accent: ' + darkHex + '; --accent-hover: rgb(' + Math.min(dark.r+30,255) + ',' + Math.min(dark.g+30,255) + ',' + Math.min(dark.b+30,255) + '); --accent-glow: rgba(' + dark.r + ',' + dark.g + ',' + dark.b + ',0.12); }';

    localStorage.setItem('accent-light', lightHex);
    localStorage.setItem('accent-dark', darkHex);
  }

  function resetAccent() {
    var style = document.getElementById('accent-style');
    if (style) style.remove();
    localStorage.removeItem('accent-light');
    localStorage.removeItem('accent-dark');
  }

  var savedLight = localStorage.getItem('accent-light');
  var savedDark = localStorage.getItem('accent-dark');
  if (savedLight && savedDark) {
    applyAccent(savedLight, savedDark);
  }

  toggle.addEventListener('click', function () {
    drawer.classList.toggle('hidden');
    drawer.classList.toggle('flex');
  });

  swatches.forEach(function (sw) {
    sw.addEventListener('click', function () {
      var light = sw.getAttribute('data-light');
      var dark = sw.getAttribute('data-dark');
      applyAccent(light, dark);
      drawer.classList.add('hidden');
      drawer.classList.remove('flex');
    });
  });

  if (resetBtn) {
    resetBtn.addEventListener('click', function () {
      resetAccent();
      drawer.classList.add('hidden');
      drawer.classList.remove('flex');
    });
  }

  document.addEventListener('click', function (e) {
    var palette = document.getElementById('color-palette');
    if (palette && !palette.contains(e.target)) {
      drawer.classList.add('hidden');
      drawer.classList.remove('flex');
    }
  });
})();
} catch (e) { console.error('ColorPalette:', e); }
</script>
