---
const { t } = Astro.props;
const tools = t.tools;
---

<section class="relative py-24 px-4 overflow-hidden" id="tools-section">
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[var(--bg-secondary)]/10 to-transparent pointer-events-none"></div>

  <div class="max-w-6xl mx-auto relative z-10">
    <div class="text-center mb-14">
      <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-[var(--accent)]/20 bg-[var(--accent)]/5 text-xs font-semibold text-[var(--accent)] mb-4">Tools & Features</span>
      <h2 class="section-title mb-4">{tools.title}</h2>
      <p class="text-[var(--text-secondary)] text-sm max-w-2xl mx-auto">{tools.desc}</p>
    </div>

    <div class="grid md:grid-cols-2 gap-5" id="tools-grid" data-reveal-stagger="0.06">
      {tools.items.map((tool, i) => (
        <div class="tool-card group glow-card relative overflow-hidden">
          <div class="flex items-start gap-4 p-5 sm:p-6">
            <div class="shrink-0 w-10 h-10 rounded-xl bg-[var(--accent)]/10 flex items-center justify-center text-[var(--accent)]">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
              </svg>
            </div>
            <div class="min-w-0">
              <h3 class="text-base font-semibold text-[var(--text)] mb-1.5">{tool.title}</h3>
              <p class="text-sm text-[var(--text-secondary)] leading-relaxed">{tool.desc}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

