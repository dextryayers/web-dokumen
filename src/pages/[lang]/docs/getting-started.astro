---
import Layout from "../../../layouts/Layout.astro";
import { translations, type Lang } from "../../../i18n/translations";
import CodeBlock from "../../../components/CodeBlock.astro";
import DocSidebar from "../../../components/docs/DocSidebar.astro";
import DocTOC from "../../../components/docs/DocTOC.astro";
import DocPagination from "../../../components/docs/DocPagination.astro";
import DocBreadcrumb from "../../../components/docs/DocBreadcrumb.astro";
import DocSearch from "../../../components/docs/DocSearch.astro";

export async function getStaticPaths() {
  return [
    { params: { lang: "en" } },
    { params: { lang: "it" } },
    { params: { lang: "id" } },
    { params: { lang: "ru" } },
    { params: { lang: "zh" } },
    { params: { lang: "ja" } },
  ];
}

const { lang } = Astro.params as { lang: Lang };
const t = translations[lang];
const d = t.docs.gettingStarted;
const headings = [
  { id: "installation", text: d.h_installation, level: 2 },
  { id: "quick-start", text: d.h_quickStart, level: 2 },
  { id: "requirements", text: d.h_requirements, level: 2 }
];

// page data

// page data
---

<Layout lang={lang} t={t}>
  <DocSidebar lang={lang} currentPath={Astro.url.pathname} headings={headings} />
  <div class="max-w-none lg:ml-96 px-6 lg:px-10 pt-24 lg:pt-28 pb-16 lg:pb-24">
    <div class="lg:flex lg:gap-0">
      <main class="flex-1 min-w-0 lg:pl-20 xl:pl-28">
        <DocBreadcrumb lang={lang} items={[{ label: d.title }]} />
        <div class="my-6"><DocSearch t={t} lang={lang} /></div>
        <h1 class="text-2xl sm:text-3xl lg:text-4xl font-extrabold gradient-text" data-reveal>{d.title}</h1>
        <p class="text-base sm:text-lg text-[var(--text-secondary)] mt-4 mb-10 leading-relaxed" data-reveal data-reveal-delay="0.1">{d.desc}</p>

        <section id="installation" class="mb-14 scroll-mt-28" data-reveal data-reveal-delay="0.2">
  <h2 class="text-xl sm:text-2xl font-bold text-[var(--text)] mb-5">{d.h_installation}</h2>
  <p class="text-sm sm:text-base text-[var(--text-secondary)] mb-6 leading-relaxed">
    HackIT is a <strong>Python-based CLI tool</strong> using the Click library. Clone the repository, install dependencies, and you are ready to go.
  </p>
  <CodeBlock code={[
    "git clone https://github.com/dextryayers/HackIT.git",
    "cd HackIT",
    "pip install -r requirements.txt"
  ].join("\n")} lang="bash" t={t} />
  <p class="text-sm sm:text-base text-[var(--text-secondary)] mb-6 leading-relaxed">
    Run it with <code class="text-[var(--accent)]">python hackit/main.py [command]</code> or <code class="text-[var(--accent)]">python -m hackit.main [command]</code>.
  </p>
</section>

<section id="quick-start" class="mb-14 scroll-mt-28" data-reveal data-reveal-delay="0.3">
  <h2 class="text-xl sm:text-2xl font-bold text-[var(--text)] mb-5">{d.h_quickStart}</h2>
  <p class="text-sm sm:text-base text-[var(--text-secondary)] mb-6 leading-relaxed">
    Once installed, HackIT exposes a unified CLI through the <code class="text-[var(--accent)]">python hackit/main.py</code> entry point. Commands are organized under CLI groups: <code class="text-[var(--accent)]">ports</code>, <code class="text-[var(--accent)]">web</code>, <code class="text-[var(--accent)]">vuln</code>, <code class="text-[var(--accent)]">recon</code>, <code class="text-[var(--accent)]">ssl</code>, and <code class="text-[var(--accent)]">util</code>.
  </p>
  <p class="text-sm sm:text-base text-[var(--text-secondary)] mb-6 leading-relaxed">
    Scan ports on a target:
  </p>
  <CodeBlock code="python hackit/main.py ports scan -p 80,443 --targets example.com" lang="bash" t={t} />
  <p class="text-sm sm:text-base text-[var(--text-secondary)] mb-6 leading-relaxed">
    Audit web application headers and technology stack:
  </p>
  <CodeBlock code="python hackit/main.py web headers --url https://target.com" lang="bash" t={t} />
  <p class="text-sm sm:text-base text-[var(--text-secondary)] mb-6 leading-relaxed">
    Run vulnerability scans for XSS and SQLi:
  </p>
  <CodeBlock code="python hackit/main.py vuln xss --url https://target.com" lang="bash" t={t} />
  <p class="text-sm sm:text-base text-[var(--text-secondary)] mb-6 leading-relaxed">
    Perform reconnaissance and OSINT gathering:
  </p>
  <CodeBlock code="python hackit/main.py recon subdomains -d target.com" lang="bash" t={t} />
  <p class="text-sm sm:text-base text-[var(--text-secondary)] mb-6 leading-relaxed">
    Launch the interactive agent or web UI:
  </p>
  <CodeBlock code="python hackit/main.py agent" lang="bash" t={t} />
</section>

<section id="requirements" class="mb-14 scroll-mt-28" data-reveal data-reveal-delay="0.4">
  <h2 class="text-xl sm:text-2xl font-bold text-[var(--text)] mb-5">{d.h_requirements}</h2>
  <p class="text-sm sm:text-base text-[var(--text-secondary)] mb-6 leading-relaxed">
    HackIT requires only <strong>Python 3.10 or later</strong>. No additional runtimes (Rust, Node.js) or container engines (Docker) are needed.
  </p>
  <p class="text-sm sm:text-base text-[var(--text-secondary)] mb-6 leading-relaxed">
    <strong class="text-[var(--text)]">Memory:</strong> 512 MB of RAM is sufficient for most modules. AI agent features may benefit from additional memory.
  </p>
  <p class="text-sm sm:text-base text-[var(--text-secondary)] mb-6 leading-relaxed">
    <strong class="text-[var(--text)]">Storage:</strong> Approximately 100 MB of disk space is required for the installation.
  </p>
  <p class="text-sm sm:text-base text-[var(--text-secondary)] mb-6 leading-relaxed">
    <strong class="text-[var(--text)]">Operating System:</strong> Linux, macOS, and Windows are all fully supported.
  </p>
  <p class="text-sm sm:text-base text-[var(--text-secondary)] mb-6 leading-relaxed">
    <strong class="text-[var(--text)]">Permissions:</strong> Root or administrator access may be required for wireless modules and raw socket operations. Most modules run under a standard user account.
  </p>
</section>
</main>
      <DocTOC headings={headings} />
    </div>
    <DocPagination lang={lang} currentPath={Astro.url.pathname} />
  </div>
</Layout>

