---
import Layout from "../../../layouts/Layout.astro";
import { translations, type Lang } from "../../../i18n/translations";
import CodeBlock from "../../../components/CodeBlock.astro";
import DocSidebar from "../../../components/docs/DocSidebar.astro";
import DocTOC from "../../../components/docs/DocTOC.astro";
import DocPagination from "../../../components/docs/DocPagination.astro";
import DocBreadcrumb from "../../../components/docs/DocBreadcrumb.astro";
import DocSearch from "../../../components/docs/DocSearch.astro";

export async function getStaticPaths() {
  return [
    { params: { lang: "en" } },
    { params: { lang: "it" } },
    { params: { lang: "id" } },
    { params: { lang: "ru" } },
    { params: { lang: "zh" } },
    { params: { lang: "ja" } },
  ];
}

const { lang } = Astro.params as { lang: Lang };
const t = translations[lang];
const d = t.docs.webFuzzing;
const headings = [
  { id: "overview", text: d.h_overview, level: 2 },
  { id: "tools", text: d.h_availableTools, level: 2 },
];

const webTools = [
  { name: d.toolsDirFinder.name, href: `/${lang}/docs/dir-finder/`, desc: d.toolsDirFinder.desc },
  { name: d.toolsHeaderAudit.name, href: `/${lang}/docs/header-audit/`, desc: d.toolsHeaderAudit.desc },
  { name: d.toolsTechDetection.name, href: `/${lang}/docs/tech-detection/`, desc: d.toolsTechDetection.desc },
  { name: d.toolsWebFuzzer.name, href: `/${lang}/docs/web-fuzzer/`, desc: d.toolsWebFuzzer.desc },
  { name: d.toolsJsAnalysis.name, href: `/${lang}/docs/js-analysis/`, desc: d.toolsJsAnalysis.desc },
  { name: d.toolsParams.name, href: `/${lang}/docs/params/`, desc: d.toolsParams.desc },
  { name: d.tools403Bypass.name, href: `/${lang}/docs/403bypass/`, desc: d.tools403Bypass.desc },
];
---

<Layout lang={lang} t={t}>
  <DocSidebar lang={lang} currentPath={Astro.url.pathname} headings={headings} />
  <div class="max-w-none lg:ml-96 px-6 lg:px-10 pt-24 lg:pt-28 pb-16 lg:pb-24">
    <div class="lg:flex lg:gap-0">
      <main class="flex-1 min-w-0 lg:pl-20 xl:pl-28">
        <DocBreadcrumb lang={lang} items={[{ label: d.title }]} />
        <div class="my-6"><DocSearch t={t} lang={lang} /></div>
        <h1 class="text-2xl sm:text-3xl lg:text-4xl font-extrabold gradient-text" data-reveal>{d.title}</h1>
        <p class="text-base sm:text-lg text-[var(--text-secondary)] mt-4 mb-10 leading-relaxed" data-reveal data-reveal-delay="0.1">{d.desc}</p>

        <section id="overview" class="mb-14 scroll-mt-28" data-reveal data-reveal-delay="0.2">
  <h2 class="text-xl sm:text-2xl font-bold text-[var(--text)] mb-5">{d.h_overview}</h2>
  <p class="text-sm sm:text-base text-[var(--text-secondary)] mb-6 leading-relaxed">
    HackIT provides a comprehensive suite of <strong class="text-[var(--text)]">web application discovery and analysis modules</strong> under the <code class="text-[var(--accent)]">web</code> command group. Each module focuses on a specific aspect of web reconnaissance, from directory enumeration and technology fingerprinting to JavaScript analysis and parameter discovery.
  </p>
  <p class="text-sm sm:text-base text-[var(--text-secondary)] mb-6 leading-relaxed">
    These modules are designed to work together in a pipeline — start with directory discovery and technology detection, then drill down with parameter fuzzing, JavaScript analysis, and vulnerability testing. For vulnerability-specific modules (XSS, SQLi, RCE, redirect), see the individual tool pages.
  </p>
  <CodeBlock code={`# Typical web discovery pipeline
hackit dirfinder --url https://target.com
hackit web tech --url https://target.com
hackit web fuzz --url https://target.com
hackit web params --url https://target.com
hackit web js --url https://target.com`} lang="bash" t={t} />
</section>

<section id="tools" class="mb-14 scroll-mt-28" data-reveal data-reveal-delay="0.3">
  <h2 class="text-xl sm:text-2xl font-bold text-[var(--text)] mb-5">{d.h_availableTools}</h2>
  <p class="text-sm sm:text-base text-[var(--text-secondary)] mb-6 leading-relaxed">
    Click on any tool below for detailed documentation, CLI syntax, and examples.
  </p>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
    {webTools.map((tool) => (
      <a href={tool.href} class="glow-card p-4 group hover:shadow-lg hover:shadow-[var(--shadow-color)] transition-all duration-200">
        <p class="font-semibold text-sm group-hover:text-[var(--accent)] transition-colors">{tool.name}</p>
        <p class="text-xs text-[var(--text-secondary)] mt-1 leading-relaxed">{tool.desc}</p>
      </a>
    ))}
  </div>
</section>
</main>
      <DocTOC headings={headings} />
    </div>
    <DocPagination lang={lang} currentPath={Astro.url.pathname} />
  </div>
</Layout>
